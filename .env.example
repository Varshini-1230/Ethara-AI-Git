# Environment Variables Template
# Copy this to .env and fill in your actual values
# DO NOT commit .env file (already in .gitignore)

# MongoDB Connection String
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname
# For Railway MongoDB: Check Railway dashboard for provided URI
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/team-task-manager

# Server Configuration
PORT=5001
NODE_ENV=development

# JWT Configuration (if using)
# JWT_SECRET=your-secret-key-here

# API Configuration
# CORS_ORIGIN=http://localhost:3000
